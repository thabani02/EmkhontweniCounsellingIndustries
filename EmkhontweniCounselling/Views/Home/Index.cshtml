@{
    ViewData["Title"] = "Home";
}

<section class="hero text-center position-relative overflow-hidden">
    <div class="container py-5">
        <h1 class="display-5 fw-bold">Because your mind deserves a royal standard of care</h1>
        <p class="lead mt-3">Professional counselling with calm, dignity, and cultural respect.</p>
        <a href="/Appointment/Book" class="btn royal-btn mt-4 px-5 py-3">
            Book Your Session
        </a>
    </div>
    <!-- African-inspired subtle pattern -->
    <img src="~/images/patterns/african_pattern.svg" class="pattern-top-left" alt="African pattern">

    <!-- Hero Illustration -->
    <img src="~/images/illustrations/calm_environment.svg" class="hero-illustration" alt="Calm counselling room">
</section>

<section class="container mt-5">
    <h2 class="section-title text-center">Our Services</h2>
    <div class="royal-divider"></div>
    <div class="row g-4 justify-content-center">
        <div class="col-md-4 service-card royal-border text-center p-4">
            <i data-lucide="user-heart" class="service-icon"></i>
            <h5>Individual Counselling</h5>
            <p>Confidential sessions focused on personal growth and emotional healing.</p>
        </div>
        <div class="col-md-4 service-card royal-border text-center p-4">
            <i data-lucide="activity" class="service-icon"></i>
            <h5>Stress Management</h5>
            <p>Guided methods to reduce stress, anxiety, and improve well-being.</p>
        </div>
        <div class="col-md-4 service-card royal-border text-center p-4">
            <i data-lucide="heart-handshake" class="service-icon"></i>
            <h5>Relationship Counselling</h5>
            <p>Build stronger connections and resolve conflicts in a safe space.</p>
        </div>
    </div>
</section>
