@{
    ViewData["Title"] = "Home";
}

<section class="hero text-center position-relative overflow-hidden">
    <div class="container py-5">
        <h1 class="display-5 fw-bold">
            Your Mind Deserves a Royal Standard of Care
        </h1>

        <p class="lead mt-3">
            At Emkhontweni Royal Industries, we provide compassionate,
            culturally-sensitive counselling services. Begin your journey
            to mental wellness in a safe, supportive environment.
        </p>

        <div class="mt-4">
            <a href="/Appointment/Book" class="btn royal-btn px-5 py-3 me-3">
                Book Your Session
            </a>

            <a href="Home/Services" class="btn btn-outline-light px-5 py-3">
                Explore Our Services
            </a>
        </div>
    </div>

    <!-- African-inspired subtle pattern -->
    <img src="~/images/patterns/african_pattern.svg"
         class="pattern-top-left"
         alt="African pattern">

    <!-- Hero Illustration -->
    <img src="~/images/illustrations/calm_environment.svg"
         class="hero-illustration"
         alt="Calm counselling room">
</section>


<!-- ===============================
     CONFIDENTIAL SECTION
================================ -->
<section class="container text-center mt-5">
    <div class="royal-border p-4 confidential-box">
        <h4 class="fw-bold">Confidential</h4>
        <p class="text-muted mb-0">
            Your privacy and dignity are protected at every stage of your journey.
            All sessions are strictly confidential and conducted with the highest
            ethical standards.
        </p>
    </div>
</section>


<!-- ===============================
     SERVICES SECTION (EXPANDED)
================================ -->
<section class="container mt-5">
    <h2 class="section-title text-center">
        Comprehensive Care for Your Mental Wellness
    </h2>

    <p class="text-center text-muted mb-4">
        We offer a range of counselling services designed to support you
        through life's journey with compassion, understanding,
        and cultural sensitivity.
    </p>

    <div class="royal-divider"></div>

    <div class="row g-4 justify-content-center">

        <!-- Individual -->
        <div class="col-md-4 service-card royal-border text-center p-4">
            <i data-lucide="user-heart" class="service-icon"></i>
            <h5>Individual Counselling</h5>
            <p>
                One-on-one sessions tailored to your unique needs,
                helping you navigate life's challenges with professional support.
            </p>
            <a href="Home/Services" class="service-link">Learn More</a>
        </div>

        <!-- Stress -->
        <div class="col-md-4 service-card royal-border text-center p-4">
            <i data-lucide="activity" class="service-icon"></i>
            <h5>Stress Management</h5>
            <p>
                Learn effective techniques to manage stress,
                build resilience, and maintain balance in your daily life.
            </p>
            <a href="Home/Services" class="service-link">Learn More</a>
        </div>

        <!-- Relationship -->
        <div class="col-md-4 service-card royal-border text-center p-4">
            <i data-lucide="heart-handshake" class="service-icon"></i>
            <h5>Relationship Counselling</h5>
            <p>
                Strengthen your relationships through improved communication,
                understanding, and conflict resolution skills.
            </p>
            <a href="Home/Services" class="service-link">Learn More</a>
        </div>

        <!-- Trauma -->
        <div class="col-md-4 service-card royal-border text-center p-4">
            <i data-lucide="shield" class="service-icon"></i>
            <h5>Trauma Counselling</h5>
            <p>
                Heal from past experiences in a safe,
                supportive environment with specialized trauma-informed care.
            </p>
            <a href="Home/Services" class="service-link">Learn More</a>
        </div>

        <!-- African Spirituality -->
        <div class="col-md-4 service-card royal-border text-center p-4">
            <i data-lucide="sun" class="service-icon"></i>
            <h5>African Spirituality & Healing</h5>
            <p>
                Embrace holistic healing that honours African traditions
                and spiritual practices for complete wellness.
            </p>
            <a href="Home/Services" class="service-link">Learn More</a>
        </div>

    </div>

    <div class="text-center mt-4">
        <a href="/Services" class="btn royal-btn px-5 py-3">
            View All Services
        </a>
    </div>
</section>
