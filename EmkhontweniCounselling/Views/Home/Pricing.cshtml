@{
    ViewData["Title"] = "Pricing";
}

<!-- ======================================
     PRICING HERO
====================================== -->
<section class="container my-5 text-center">
    <h2 class="section-title">Affordable Mental Wellness</h2>
    <div class="royal-divider"></div>

    <p class="text-muted mx-auto" style="max-width: 700px;">
        We believe quality mental health care should be accessible to everyone.
        Our pricing is designed to be affordable without compromising on care.
    </p>
</section>

<!-- ======================================
     INTAKE FEES
====================================== -->
<section class="container my-5">
    <h4 class="text-center mb-4">One-Time Intake Fees</h4>
    <p class="text-center text-muted mb-5">
        Initial assessment to understand your needs and create a personalized plan.
    </p>

    <div class="row justify-content-center g-4">
        <div class="col-md-4">
            <div class="price-card royal-border p-4 text-center floating-card">
                <h5>Individual Intake</h5>
                <p class="price">R50</p>
                <small class="text-muted">One-time assessment fee</small>
            </div>
        </div>

        <div class="col-md-4">
            <div class="price-card royal-border p-4 text-center floating-card">
                <h5>Couples Intake</h5>
                <p class="price">R100</p>
                <small class="text-muted">One-time assessment fee</small>
            </div>
        </div>
    </div>
</section>

<!-- ======================================
     SESSION PRICING
====================================== -->
<section class="container my-5">
    <h4 class="text-center mb-4">Per Session Pricing</h4>
    <p class="text-center text-muted mb-5">
        Choose the session type that best fits your needs.
        All sessions include our full range of therapeutic services.
    </p>

    <div class="row justify-content-center g-4">

        <!-- STUDENT SESSION -->
        <div class="col-md-4">
            <div class="price-card royal-border p-4 text-center floating-card">
                <span class="badge popular-badge">Student</span>
                <h5>Student Session</h5>
                <p class="price">R150<span class="fs-6">/session</span></p>

                <ul class="pricing-features">
                    <li>Valid student ID required</li>
                    <li>Ages 17–22 only</li>
                    <li>All counselling services included</li>
                </ul>

                <a href="/Appointment/Book?service=Student Session"
                   class="btn royal-btn w-100 mt-3">
                    Book Now
                </a>
            </div>
        </div>

        <!-- INDIVIDUAL SESSION -->
        <div class="col-md-4">
            <div class="price-card royal-border p-4 text-center floating-card highlighted">
                <span class="badge popular-badge">Popular</span>
                <h5>Individual Session</h5>
                <p class="price">R250<span class="fs-6">/session</span></p>

                <ul class="pricing-features">
                    <li>One-on-one counselling</li>
                    <li>All therapy modalities</li>
                    <li>Flexible scheduling</li>
                    <li>Progress tracking</li>
                </ul>

                <a href="/Appointment/Book?service=Individual Session"
                   class="btn royal-btn w-100 mt-3">
                    Book Now
                </a>
            </div>
        </div>

        <!-- COUPLES SESSION -->
        <div class="col-md-4">
            <div class="price-card royal-border p-4 text-center floating-card">
                <h5>Couples Session</h5>
                <p class="price">R300<span class="fs-6">/session</span></p>

                <ul class="pricing-features">
                    <li>Joint counselling session</li>
                    <li>Communication coaching</li>
                    <li>Conflict resolution</li>
                    <li>Relationship assessment</li>
                </ul>

                <a href="/Appointment/Book?service=Couples Session"
                   class="btn royal-btn w-100 mt-3">
                    Book Now
                </a>
            </div>
        </div>

    </div>
</section>

<!-- ======================================
     OUR PROMISE
====================================== -->
<section class="container my-5 text-center">
    <h4 class="mb-4">Our Promise to You</h4>

    <p class="text-muted mx-auto" style="max-width: 800px;">
        We understand that seeking help takes courage. That’s why we ensure
        complete confidentiality, compassionate care, and transparent pricing.
        There are no hidden fees — what you see is what you pay.
    </p>

    <div class="row justify-content-center mt-4">
        <div class="col-md-3 text-muted">✔ 100% Confidential Sessions</div>
        <div class="col-md-3 text-muted">✔ Compassionate, Non-Judgmental Care</div>
        <div class="col-md-3 text-muted">✔ Professional, Qualified Counsellors</div>
    </div>
</section>
