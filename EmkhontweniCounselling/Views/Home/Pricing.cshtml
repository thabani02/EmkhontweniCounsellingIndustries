@{
    ViewData["Title"] = "Pricing";
}

<section class="pricing-section py-5">
    <div class="container text-center">

        <h2 class="fw-bold mb-3">Affordable Mental Wellness</h2>
        <p class="lead mb-4">
            We believe quality mental health care should be accessible to everyone.
            Our pricing is designed to be affordable without compromising on care.
        </p>

        <h4 class="mb-4">Per Session Pricing</h4>
        <p class="text-muted">
            Choose the session type that best fits your needs.
            All sessions include our full range of therapeutic services.
        </p>

        <!-- Pricing Cards -->
        <div class="row justify-content-center g-4 mt-4">

            <!-- Main Visible Services -->
           <div class="row justify-content-center g-4 mt-4">

    <!-- Student Session -->
    <div class="col-md-4">
        <div class="price-card shadow p-3">
            <h5>Student Session</h5>
            <p class="text-muted small">
                A special session for students. Requires valid student ID, proof of registration, and acceptance letter.
            </p>
            <h3 class="price">R150</h3>
            <a href="/Appointment/Book?service=Student Session" class="btn btn-success w-100">Book Now</a>
        </div>
    </div>

    <!-- Individual Session -->
    <div class="col-md-4">
        <div class="price-card shadow p-3">
            <h5>Individual Session</h5>
            <p class="text-muted small">
                One-on-one session to address personal mental wellness, stress, and emotional support.
            </p>
            <h3 class="price">R250</h3>
            <a href="/Appointment/Book?service=Individual Session" class="btn btn-success w-100">Book Now</a>
        </div>
    </div>

    <!-- Couples Session -->
    <div class="col-md-4">
        <div class="price-card shadow p-3">
            <h5>Couples Session</h5>
            <p class="text-muted small">
                Designed for couples to improve communication, resolve conflicts, and strengthen relationships.
            </p>
            <h3 class="price">R300</h3>
            <a href="/Appointment/Book?service=Couples Session" class="btn btn-success w-100">Book Now</a>
        </div>
    </div>
</div>

            <!-- Hidden Services -->
            <div id="moreServices" class="row justify-content-center g-4 mt-3 hidden-services">
                <div class="col-md-4">
                    <div class="price-card shadow">
                        <h5>Stress Management</h5>
                        <h3 class="price">R250</h3>
                        <a href="/Appointment/Book?service=Stress Management" class="btn btn-success w-100">Book Now</a>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="price-card shadow">
                        <h5>Trauma Counselling</h5>
                        <h3 class="price">R250</h3>
                        <a href="/Appointment/Book?service=Trauma Counselling" class="btn btn-success w-100">Book Now</a>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="price-card shadow">
                        <h5>African Spirituality & Healing</h5>
                        <h3 class="price">R250</h3>
                        <a href="/Appointment/Book?service=African Spirituality & Healing" class="btn btn-success w-100">Book Now</a>
                    </div>
                </div>
            </div>

        <!-- Arrow Button -->
        <div class="mt-4">
            <button id="toggleBtn" class="btn btn-outline-dark">
                <span id="arrow">&#9660;</span> View More Services
            </button>
        </div>

        <!-- Promise Section -->
        <div class="mt-5 promise-box p-4 shadow-sm">
            <h4>Our Promise to You</h4>
            <p>
                We understand that seeking help takes courage.
                That’s why we ensure complete confidentiality, compassionate care,
                and transparent pricing. There are no hidden fees — what you see is what you pay.
            </p>

            <p class="mb-0">
                ✔ 100% Confidential Sessions <br />
                ✔ Compassionate, Non-Judgmental Care <br />
                ✔ Professional, Qualified Counsellors
            </p>
        </div>

    </div>
</section>

<style>
    .price-card {
        background: #fff;
        padding: 30px;
        border-radius: 15px;
        transition: transform 0.3s ease;
    }

        .price-card:hover {
            transform: translateY(-8px);
        }

    .price {
        color: #198754;
        margin: 15px 0;
    }

    .hidden-services {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.6s ease;
    }

        .hidden-services.show {
            max-height: 800px;
        }

    #arrow {
        display: inline-block;
        transition: transform 0.3s ease;
    }

    .rotate {
        transform: rotate(180deg);
    }

    .promise-box {
        background: #f8f9fa;
        border-radius: 15px;
    }
</style>

<script>
    const toggleBtn = document.getElementById("toggleBtn");
    const moreServices = document.getElementById("moreServices");
    const arrow = document.getElementById("arrow");

    toggleBtn.addEventListener("click", function () {
        moreServices.classList.toggle("show");
        arrow.classList.toggle("rotate");

        toggleBtn.innerHTML = moreServices.classList.contains("show")
            ? '<span id="arrow">&#9650;</span> Show Less'
            : '<span id="arrow">&#9660;</span> View More Services';
    });
</script>