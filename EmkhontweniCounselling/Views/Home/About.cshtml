@{
    ViewData["Title"] = "About Us";
}

<section class="about-hero text-center text-white d-flex align-items-center">
    <div class="container">
        <h1 class="display-4 fw-bold">A Royal Standard of Mental Health Care</h1>
        <p class="lead mt-3">
            Compassion. Culture. Confidentiality. Excellence.
        </p>
    </div>
</section>

<section class="container my-5">

    <!-- INTRO -->
    <div class="row mb-5">
        <div class="col-lg-10 mx-auto text-center">
            <p class="fs-5 text-muted">
                At <strong>Emkhotweni Royal Counselling</strong>, we believe healing is sacred.
                Every individual deserves compassionate, professional, and culturally grounded mental health support.
                We combine modern therapeutic practices with African spirituality and healing traditions
                to nurture the mind, body, and spirit.
            </p>
        </div>
    </div>

    <!-- MISSION -->
    <div class="row align-items-center mb-5">
        <div class="col-md-6">
            <h2 class="fw-bold mb-3"> Our Mission</h2>
            <p class="text-muted">
                We are dedicated to providing accessible, affordable, and holistic counselling services.
                Our approach recognizes the deep interconnection between emotional wellbeing,
                spiritual alignment, and personal growth.
            </p>
            <p class="text-muted">
                We create safe, empowering spaces where individuals and couples can reflect,
                heal, and transform with dignity and purpose.
            </p>
        </div>
        <div class="col-md-6 text-center">
            <div class="mission-box p-4 shadow-lg rounded-4">
                <h4 class="fw-bold">“Healing is not a luxury — it is a birthright.”</h4>
            </div>
        </div>
    </div>

    <!-- CORE VALUES -->
    <div class="text-center mb-4">
        <h2 class="fw-bold">Our Core Values</h2>
        <div class="royal-divider mx-auto"></div>
    </div>

    <div class="row g-4">

        <div class="col-md-3">
            <div class="value-card text-center p-4 shadow-sm rounded-4">
                <h5 class="fw-bold">Compassion</h5>
                <p class="text-muted small">
                    We approach every client with warmth, empathy,
                    and genuine care for their wellbeing.
                </p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="value-card text-center p-4 shadow-sm rounded-4">
                <h5 class="fw-bold">Confidentiality</h5>
                <p class="text-muted small">
                    Your privacy is sacred. All sessions are conducted
                    in strict confidence and professionalism.
                </p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="value-card text-center p-4 shadow-sm rounded-4">
                <h5 class="fw-bold">Cultural Sensitivity</h5>
                <p class="text-muted small">
                    We honour African traditions and integrate
                    culturally informed healing practices.
                </p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="value-card text-center p-4 shadow-sm rounded-4">
                <h5 class="fw-bold">Excellence</h5>
                <p class="text-muted small">
                    We uphold a royal standard of mental health care —
                    ethical, professional, and transformative.
                </p>
            </div>
        </div>

    </div>
</section>