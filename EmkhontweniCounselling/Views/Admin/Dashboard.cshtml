@model List<EmkhontweniCounselling.Models.Appointment>

@{
    ViewData["Title"] = "Admin Dashboard";
}

<section class="container my-5">
    <div class="d-flex justify-content-end mb-3">
        <a asp-controller="Admin"
           asp-action="Logout"
           class="btn btn-danger">
            Logout
        </a>
    </div>

    <h2 class="section-title text-center">Admin Dashboard</h2>
    <div class="royal-divider"></div>

    <!-- ===============================
         SEARCH + FILTER BAR
    =============================== -->
    <form method="get" class="row g-3 mb-4 align-items-end">

        <!-- SEARCH -->
        <div class="col-md-4">
            <label class="form-label">Search Client</label>
            <input name="search"
                   value="@ViewBag.Search"
                   class="form-control"
                   placeholder="Name or email" />
        </div>

        <!-- YEAR -->
        <div class="col-md-3">
            <label class="form-label">Year</label>
            <select name="year" class="form-select">
                <option value="">All Years</option>
                @foreach (int y in ViewBag.Years)
                {
                    var isSelected = (ViewBag.SelectedYear == y);
                    <option value="@y" selected="@(isSelected ? "selected" : null)">@y</option>
                }
            </select>
        </div>

        <!-- MONTH -->
<div class="col-md-3">
    <label class="form-label">Month</label>
    <select name="month" class="form-select">
        <option value="">All Months</option>
        @for (int m = 1; m <= 12; m++)
{
    var isSelected = (ViewBag.SelectedMonth == m);
    <option value="@m" selected="@(isSelected ? "selected" : null)">
        @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)
    </option>
}
    </select>
</div>

        <div class="col-md-2">
            <button class="btn royal-btn w-100">Filter</button>
        </div>
    </form>

    <!-- ===============================
         APPOINTMENTS TABLE
    =============================== -->
    <div class="table-responsive admin-table">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Booked On</th>
                    <th>Client</th>
                    <th>Service</th>
                    <th>Amount</th>
                    <th>Payment</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var a in Model)
                {
                    <tr>
                        <!-- BOOKING DATE -->
                        <td>
                            @a.AppointmentDate?.ToString("dd MMM yyyy")
                        </td>

                        <td>
                            <strong>@a.Client.FullName</strong><br />
                            <small class="text-muted">@a.Client.Email</small>
                        </td>

                        <td>@a.ServiceType</td>
                        <td>R @a.Amount</td>

                        <!-- PAYMENT STATUS -->
                        <td>
                            @if (a.IsPaymentVerified)
                            {
                                <span class="badge bg-success">Verified</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Not Verified</span>
                            }
                        </td>

                        <!-- APPOINTMENT STATUS -->
                        <td>
                            <span class="status-pill @a.Status?.ToLower()">
                                @a.Status
                            </span>
                        </td>

                        <!-- ACTIONS -->
                        <td class="text-nowrap">
                            <a href="/Admin/TogglePayment/@a.AppointmentId"
                               class="btn btn-sm btn-outline-primary me-1">
                                @(a.IsPaymentVerified ? "✖" : "✔")
                            </a>

                            @if (a.IsPaymentVerified)
                            {
                                <a href="/Admin/UpdateStatus/@a.AppointmentId?status=Accepted"
                                   class="btn btn-sm btn-success me-1">
                                    Accept
                                </a>
                                <a href="/Admin/UpdateStatus/@a.AppointmentId?status=Rejected"
                                   class="btn btn-sm btn-danger">
                                    Reject
                                </a>

                            }

                            <a href="/Admin/Reschedule/@a.AppointmentId"
                               class="btn btn-sm btn-secondary me-1">
                                Reschedule
                            </a>
                            <!-- DELETE -->
                            <button class="btn btn-sm btn-outline-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteModal-@a.AppointmentId">
                                Delete
                            </button>
                                
                                
                        </td>
                    </tr>
                    <!-- DELETE MODAL -->
                    <div class="modal fade"
                         id="deleteModal-@a.AppointmentId"
                         tabindex="-1"
                         aria-hidden="true">
                        <div class="modal-dialog">
                            <div class="modal-content royal-border">

                                <div class="modal-header">
                                    <h5 class="modal-title">Confirm Deletion</h5>
                                    <button type="button"
                                            class="btn-close"
                                            data-bs-dismiss="modal"></button>
                                </div>

                                <div class="modal-body">
                                    Are you sure you want to delete this booking for
                                    <strong>@a.Client.FullName</strong>?
                                    <br /><br />
                                    <span class="text-danger">
                                        This action cannot be undone.
                                    </span>
                                </div>

                                <div class="modal-footer">
                                    <button type="button"
                                            class="btn btn-secondary"
                                            data-bs-dismiss="modal">
                                        Cancel
                                    </button>

                                    <form method="post"
                                          asp-action="DeleteAppointment"
                                          asp-controller="Admin">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden"
                                               name="id"
                                               value="@a.AppointmentId" />

                                        <button type="submit"
                                                class="btn btn-danger">
                                            Yes, Delete
                                        </button>
                                    </form>
                                </div>

                            </div>
                        </div>
                    </div>
                }
            </tbody>
        </table>
    </div>

</section>
