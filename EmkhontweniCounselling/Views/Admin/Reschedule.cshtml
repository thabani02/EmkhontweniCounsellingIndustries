@model EmkhontweniCounselling.Models.Appointment

<section class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="booking-card royal-border">

                <h4 class="mb-3">Reschedule Appointment</h4>

                <p class="text-muted">
                    Client: <strong>@Model.Client.FullName</strong><br />
                    Service: <strong>@Model.ServiceType</strong>
                </p>

                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">New Date & Time</label>
                        <input type="datetime-local"
                               name="newDateTime"
                               class="form-control royal-input"
                               required />
                    </div>

                    <button class="btn royal-btn w-100">
                        Save Changes
                    </button>

                    <a href="/Admin/Dashboard"
                       class="btn btn-outline-secondary w-100 mt-2">
                        Cancel
                    </a>
                </form>

            </div>

        </div>
    </div>
</section>
