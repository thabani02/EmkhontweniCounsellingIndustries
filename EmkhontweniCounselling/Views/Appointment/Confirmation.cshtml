@{
    ViewData["Title"] = "Booking Confirmation";
}

<section class="container my-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="booking-card royal-border p-5">

                <i data-lucide="check-circle"
                   style="width:60px;height:60px;color:green;"></i>

                <h2 class="mt-3">Appointment Request Received</h2>

                <p class="text-muted mt-3">
                    Thank you for booking with Emkhontweni Royal Industries.
                    Your appointment has been submitted successfully.
                </p>

                <p class="text-muted">
                    Our team will review your request and confirm your
                    session shortly.
                </p>

                <a href="/"
                   class="btn royal-btn mt-4 px-4 py-2">
                    Return Home
                </a>

                <a href="/Appointment/Book"
                   class="btn btn-outline-secondary mt-2 px-4 py-2">
                    Book Another Session
                </a>

            </div>

        </div>
    </div>
</section>