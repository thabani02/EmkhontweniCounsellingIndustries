@model EmkhontweniCounselling.Models.Appointment

@{
    ViewData["Title"] = "Book Appointment";
}

<section class="container my-5">
    <div class="row g-5 align-items-start">

        <!-- ============================
             BOOKING FORM
        ============================= -->
        <div class="col-lg-7">
            <div class="booking-card royal-border">

                <h3 class="mb-4">Book Your Counselling Session</h3>

                <form asp-action="Book" method="post">
                    @Html.AntiForgeryToken()

                    <!-- CLIENT DETAILS -->
                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <input name="FullName"
                               class="form-control royal-input"
                               placeholder="Enter your full name"
                               required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email Address</label>
                        <input name="Email"
                               type="email"
                               class="form-control royal-input"
                               placeholder="you@example.com"
                               required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Phone Number</label>
                        <input name="PhoneNumber"
                               class="form-control royal-input"
                               placeholder="e.g. 071 234 5678"
                               required />
                    </div>

                    <!-- SESSION DETAILS -->
                    <h6 class="mt-4 mb-3">Session Details</h6>

                    <!-- SERVICE (AUTO-BOUND FROM CONTROLLER) -->
                    <div class="mb-3">
                        <label class="form-label">Selected Service</label>
                        <input asp-for="ServiceType"
                               class="form-control royal-input"
                               value="@ViewBag.Service"
                               readonly />
                    </div>

                    <!-- AMOUNT (AUTO-BOUND FROM CONTROLLER) -->
                    <div class="mb-3">
                        <label class="form-label">Amount Payable</label>
                        <input asp-for="Amount"
                               class="form-control royal-input"
                               value="@ViewBag.Amount"
                               readonly />
                    </div>

                    <!-- DATE -->
                    <div class="mb-4">
                        <label class="form-label">Preferred Date & Time</label>
                        <input asp-for="AppointmentDate"
                               type="datetime-local"
                               class="form-control royal-input"
                               required />
                    </div>

                    <p class="text-muted small mb-4">
                        All sessions are confidential and handled with dignity,
                        care, and professionalism.
                    </p>

                    <button type="submit"
                            class="btn royal-btn w-100 py-3">
                        Submit Booking
                    </button>
                </form>

            </div>
        </div>

        <!-- ============================
             PAYMENT INSTRUCTIONS
        ============================= -->
        <div class="col-lg-5">
            <div class="payment-info-card royal-border">

                <h5 class="mb-3">Payment Instructions</h5>

                <p class="fw-semibold">
                    Amount Due: <span class="text-primary">R @ViewBag.Amount</span>
                </p>

                <hr />

                <p><strong>Bank Name:</strong> Standard Bank</p>
                <p><strong>Branch:</strong> Musgrave Centre</p>
                <p><strong>Branch Code:</strong> 2726</p>
                <p><strong>Account Holder:</strong> Ms AP Zulu</p>
                <p><strong>Account Number:</strong> 10235325757</p>
                <p><strong>Account Type:</strong> Current</p>

                <hr />

                <p class="text-muted small">
                    Please make payment using your full name as the reference
                    and email your proof of payment to:
                </p>

                <p class="fw-semibold">
                    EmkhontweniRoyalIndustries@gmail.com
                </p>

            </div>
        </div>

    </div>
</section>
